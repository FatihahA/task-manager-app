datasource db {
  provider = "postgresql"
} 

generator client {
  provider = "prisma-client-js"
}

model User {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  task_lists TaskList[]
  tags       Tag[]
}

model TaskList {
  id           Int       @id @default(autoincrement())
  user_id      Int
  title        String
  created_at   DateTime  @default(now())
  list_type    String?   // "daily" | "weekly" | null
  generated_at DateTime? // when the scheduler created this list
  expires_at   DateTime? // when this list should be cleaned up

  user  User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks Task[]
}

model Task {
  id           Int       @id @default(autoincrement())
  title        String
  description  String?
  completed    Boolean   @default(false)
  status       String    @default("pending")
  deadline     DateTime?
  start_time   DateTime?
  end_time     DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?
  task_list_id Int?
  list_type    String?   // "daily" | "weekly" | null — user override for scheduler

  task_list TaskList?  @relation(fields: [task_list_id], references: [id])
  task_tags TaskTag[]
  files     TaskFile[]
}

model Tag {
  id      Int     @id @default(autoincrement())
  name    String
  color   String?
  user_id Int

  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task_tags TaskTag[]

  @@unique([user_id, name]) // Unique tag name per user
}

model TaskFile {
  id         Int      @id @default(autoincrement())
  task_id    Int
  filename   String
  filepath   String
  mimetype   String
  created_at DateTime @default(now())

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model TaskTag {
  task_id Int
  tag_id  Int

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([task_id, tag_id])
}
